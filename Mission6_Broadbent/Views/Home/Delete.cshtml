@{
    ViewData["Title"] = "Delete";
}

@* This is the model I want to use in this view *@
@model MovieRating 


<h2>Confirm Deletion</h2>
<h3>Are you sure you would like to delete @Model.Title</h3>
<form method="post">
    <input type="hidden" asp-for="@Model.MovieId">
    <button type="submit">Delete</button>
    <a class="btn btn-info" asp-controller="Home" asp-action="ViewMovies">Cancel</a>

</form>